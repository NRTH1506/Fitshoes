    {
      "name": "Auth",
      "item": [
        {
          "name": "Register User",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const unique = Date.now();",
                  "const email = `fitshoes.test.${unique}@example.com`;",
                  "pm.collectionVariables.set('testEmail', email);",
                  "pm.collectionVariables.set('testName', `FitShoes Test ${unique}`);"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Register returns 201 or 503 when DB is unavailable', function () {",
                  "  pm.expect([201, 503]).to.include(pm.response.code);",
                  "});",
                  "const json = pm.response.json();",
                  "if (pm.response.code === 201) {",
                  "  pm.test('Register succeeded', function () {",
                  "    pm.expect(json.success).to.eql(true);",
                  "    pm.expect(json.email).to.eql(pm.collectionVariables.get('testEmail'));",
                  "  });",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"{{testName}}\",\n  \"email\": \"{{testEmail}}\",\n  \"password\": \"{{testPassword}}\",\n  \"phone\": \"0123456789\",\n  \"gender\": \"male\",\n  \"address\": \"Ho Chi Minh City\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/register",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "register"
              ]
