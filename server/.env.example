# Environment variables for demo-fixcode server
# NOTE: keep this file private — do NOT commit real secrets to version control.

# Server port
PORT=8081

# MongoDB connection string
MONGO_URI=mongodb+srv://your_db_user:your_db_password@cluster0.jq9o1hr.mongodb.net/fitshoes?appName=Cluster0

# Google OAuth2 Client ID (Web application) for verifying ID tokens
# Replace this value with your own client id from Google Cloud Console
GOOGLE_CLIENT_ID=your_google_client_id_here.apps.googleusercontent.com

# Comma-separated list of allowed frontend origins for CORS
FE_ORIGINS=http://localhost:5173,http://localhost:8080,http://localhost:8081

# Environment
NODE_ENV=development

# Gmail account used for sending emails (must be the same as test user in Google Cloud)
GMAIL_USER=your_main_email@gmail.com

# Google API Credentials (OAuth2) for Gmail API
GOOGLE_API_CLIENT_ID=your_client_id_here
GOOGLE_API_CLIENT_SECRET=your_client_secret_here
GOOGLE_API_REFRESH_TOKEN=your_refresh_token_here

# Gemini API Key (Required for Chatbot)
GEMINI_API_KEY=your_gemini_api_key_here

# OpenAI API Key (Fallback if GEMINI_API_KEY is missing)
OPENAI_API_KEY=your_openai_api_key_here
